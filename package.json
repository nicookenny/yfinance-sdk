{
  "name": "yf-sdk",
  "version": "0.1.1",
  "description": "YF SDK — a typed TypeScript port of yfinance: Yahoo Finance market data for Node.js",
  "type": "module",
  "license": "Apache-2.0",
  "author": "nicokenny",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicookenny/Yahoo-Finance-SDK.git"
  },
  "bugs": {
    "url": "https://github.com/nicookenny/Yahoo-Finance-SDK/issues"
  },
  "homepage": "https://github.com/nicookenny/Yahoo-Finance-SDK#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "yahoo",
    "finance",
    "yfinance",
    "yf-sdk",
    "stocks",
    "etf",
    "options",
    "market-data",
    "ticker",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
